# =============================================================================
# RAG Document QA - Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- LLM Provider Keys ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- AWS (for Bedrock) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# --- PGVector ---
PGVECTOR_CONNECTION_STRING=postgresql+psycopg2://user:password@localhost:5432/rag_db

# --- Config Overrides (RAG_<SECTION>__<KEY>) ---
# RAG_LLM__PROVIDER=openai
# RAG_LLM__MODEL=gpt-4o-mini
# RAG_LLM__TEMPERATURE=0.0
# RAG_LLM__MAX_TOKENS=2048
# RAG_EMBEDDING__PROVIDER=openai
# RAG_EMBEDDING__MODEL=text-embedding-3-small
# RAG_EMBEDDING__DIMENSIONS=1536
# RAG_CHUNKING__STRATEGY=recursive
# RAG_CHUNKING__CHUNK_SIZE=1000
# RAG_CHUNKING__OVERLAP=200
# RAG_VECTORSTORE__PROVIDER=chroma
# RAG_VECTORSTORE__COLLECTION_NAME=documents
# RAG_VECTORSTORE__PERSIST_DIRECTORY=./chroma_data
# RAG_VECTORSTORE__PGVECTOR_CONNECTION_STRING=postgresql+psycopg2://user:password@localhost:5432/rag_db
# RAG_RETRIEVAL__TOP_K=5
# RAG_RETRIEVAL__SEARCH_TYPE=mmr
# RAG_RETRIEVAL__MMR_LAMBDA=0.5
# RAG_RETRIEVAL__RERANKER_ENABLED=false
# RAG_API__HOST=0.0.0.0
# RAG_API__PORT=8000
# RAG_API__CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# RAG_LOGGING__LEVEL=INFO
# RAG_LOGGING__FORMAT=json
